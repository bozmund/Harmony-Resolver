# Copy values into a root-readable environment file outside the repository for production.
ConnectionStrings__PostgreSql=Host=postgres;Database=harmony;Username=harmony;Password=replace-me
ConnectionStrings__Valkey=valkey:6379
ObjectStorage__Endpoint=http://minio:9000
ObjectStorage__AccessKey=replace-me
ObjectStorage__SecretKey=replace-me
ObjectStorage__Bucket=harmony-audio
Quotas__IdentityHmacKey=replace-with-at-least-32-random-bytes
Auth0__Domain=tenant.eu.auth0.com
Auth0__Audience=https://harmony-resolver
Audit__HmacKey=replace-with-at-least-32-random-bytes
