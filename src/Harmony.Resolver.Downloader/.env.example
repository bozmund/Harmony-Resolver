# Harmony Resolver downloader agent — copy to .env and fill in.
# The agent claims ingestion jobs from the resolver and fetches their audio with yt-dlp on this
# machine's (residential) IP, then uploads the raw file for the resolver to normalize and cache.

# Resolver base URL (the public HTTPS endpoint in production, or http://localhost:8088 for local test).
RESOLVER_BASE_URL=https://harmony-resolver.duckdns.org

# Auth0 machine-to-machine credentials with the `tracks:ingest` scope. Required against a real
# resolver; leave AUTH0_DOMAIN unset only when testing against a Development resolver running open.
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=https://harmony-resolver

# RabbitMQ job queue (recommended). When set, the agent reacts to job doorbells instantly instead of
# polling. Use the per-downloader RabbitMQ user the operator created; the host is the resolver's public
# hostname on the TLS AMQP port 5671. When unset, the agent falls back to the fixed-interval claim poll.
RABBITMQ_URI=amqps://downloader:replace-me@harmony-resolver.duckdns.org:5671/
RABBITMQ_QUEUE=harmony.ingest.jobs
# SHA-256 fingerprint printed by deploy/bootstrap-oracle-vps.sh. Required for its self-signed cert.
RABBITMQ_CERT_SHA256=

# Tuning (optional).
DOWNLOADER_POLL_SECONDS=5
DOWNLOADER_MAX_PARALLEL=1
DOWNLOADER_MAX_DURATION_MINUTES=9
YTDLP_PATH=yt-dlp
DOWNLOAD_TIMEOUT_SECONDS=300
