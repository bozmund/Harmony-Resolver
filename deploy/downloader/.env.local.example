# Local delegated-mode test. Used by deploy/downloader/compose.yaml on Docker Desktop.
# This intentionally uses non-TLS AMQP over the Docker Desktop host bridge; do not use it
# outside a local development machine.
RESOLVER_BASE_URL=http://host.docker.internal:8088
RABBITMQ_URI=amqp://harmony:development-only-rabbitmq@host.docker.internal:5672/
RABBITMQ_QUEUE=harmony.ingest.jobs

# The Development resolver leaves worker endpoints open, so Auth0 is intentionally omitted.
DOWNLOADER_MAX_PARALLEL=1
DOWNLOAD_TIMEOUT_SECONDS=300
