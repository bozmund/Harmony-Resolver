# Home downloader agent configuration. Copy to .env and fill in.

# The resolver's public HTTPS endpoint.
RESOLVER_BASE_URL=https://harmony-resolver.duckdns.org

# Auth0 machine-to-machine credentials authorized for the `tracks:ingest` scope.
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=https://harmony-resolver

# RabbitMQ job queue (recommended) — react to job doorbells instantly instead of polling. Use the
# per-downloader RabbitMQ user the operator created; port 5671 is the resolver's TLS AMQP listener.
# The bootstrap script prints the SHA-256 fingerprint of its self-signed certificate. Copy it below
# so the downloader authenticates the broker without disabling TLS verification.
RABBITMQ_URI=amqps://downloader:replace-me@harmony-resolver.duckdns.org:5671/
RABBITMQ_QUEUE=harmony.ingest.jobs
RABBITMQ_CERT_SHA256=

# Tuning (optional).
DOWNLOADER_POLL_SECONDS=5
DOWNLOADER_MAX_PARALLEL=1
DOWNLOADER_MAX_DURATION_MINUTES=9
DOWNLOAD_TIMEOUT_SECONDS=300
