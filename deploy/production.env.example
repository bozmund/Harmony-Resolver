# Copy to a root-readable file outside the repository, e.g. /etc/harmony-resolver/harmony-resolver.env,
# with real generated values. Never commit the filled-in file. Generate each secret with:
#   openssl rand -hex 32
POSTGRES_PASSWORD=replace-me
MINIO_ROOT_USER=harmony
MINIO_ROOT_PASSWORD=replace-me
IDENTITY_HMAC_KEY=replace-me
AUDIT_HMAC_KEY=replace-me
