# Copy to a root-readable file outside the repository, e.g. /etc/harmony-resolver/harmony-resolver.env,
# with real generated values. Never commit the filled-in file. Generate each secret with:
#   openssl rand -hex 32
POSTGRES_PASSWORD=replace-me
MINIO_ROOT_USER=harmony
MINIO_ROOT_PASSWORD=replace-me
IDENTITY_HMAC_KEY=replace-me
AUDIT_HMAC_KEY=replace-me

# Auth0 (see https://manage.auth0.com). AUTH0_DOMAIN is your tenant, shared
# by both APIs below. Resolver auth is optional (raises anonymous callers to
# the authenticated quota tier); MCP auth is required outside Development,
# and mcp will refuse to start without AUTH0_DOMAIN + AUTH0_DIAGNOSTICS_AUDIENCE.
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_AUDIENCE=https://harmony-resolver
AUTH0_DIAGNOSTICS_AUDIENCE=https://harmony-resolver-diagnostics
