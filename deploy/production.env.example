# Copy to a root-readable file outside the repository, e.g. /etc/harmony-resolver/harmony-resolver.env,
# with real generated values. Never commit the filled-in file. Generate each secret with:
#   openssl rand -hex 32
POSTGRES_PASSWORD=replace-me
MINIO_ROOT_USER=harmony
MINIO_ROOT_PASSWORD=replace-me
IDENTITY_HMAC_KEY=replace-me
AUDIT_HMAC_KEY=replace-me
# RabbitMQ admin password used by the API replicas and as the base broker login. Only relevant when
# Resolver__ExtractionMode=Delegated; give each downloader its own limited user (see README).
RABBITMQ_PASSWORD=replace-me
# Keep Inline for the first deploy. Change to Delegated only after a home downloader is connected.
RESOLVER_EXTRACTION_MODE=Inline

# Auth0 domain and diagnostics audience are not secret (they're a public
# tenant hostname and token audience, visible in any issued JWT), so they're
# committed directly in compose.prod.yaml rather than kept here.
#
# AUTH0_AUDIENCE is the resolver's own (optional) API identifier, only
# needed if you want authenticated callers to get the higher quota tier
# (see https://manage.auth0.com -> APIs -> Create API). Leave unset to keep
# the resolver anonymous-only.
AUTH0_AUDIENCE=https://harmony-resolver
